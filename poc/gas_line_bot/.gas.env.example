# Copy this file to .gas.env, then fill in your Apps Script project ID.
#
# You can find the Script ID from:
# 1. Apps Script editor URL:
#    https://script.google.com/home/projects/<SCRIPT_ID>/edit
# 2. Apps Script project settings:
#    Project Settings -> Script ID
#
# Keep .gas.env local. Do not publish it.
GAS_SCRIPT_ID=
GAS_SPREADSHEET_ID=
